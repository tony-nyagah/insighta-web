# Web Portal Configuration
# Copy to .env and fill in real values before running

# Server port (default: 3000)
WEB_PORT=3000

# Backend API base URL
INSIGHTA_API_URL=http://localhost:8080

# gorilla/securecookie — HMAC key (must be exactly 32 or 64 bytes)
SESSION_HASH_KEY=change-me-32-bytes-1234567890ab

# gorilla/securecookie — AES block encryption key (must be 16, 24, or 32 bytes)
SESSION_BLOCK_KEY=change-me-16byte

# gorilla/csrf auth key (must be exactly 32 bytes)
CSRF_AUTH_KEY=change-me-csrf-key-32bytes12345678

# Set to "production" to enable Secure + HTTPS-only cookies
ENV=development

# Override template/static directories (optional; defaults to "templates" and "static")
# TEMPLATE_DIR=templates
# STATIC_DIR=static
